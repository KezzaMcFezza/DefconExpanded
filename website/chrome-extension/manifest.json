{
  "manifest_version": 3,
  "name": "Replay Viewer Extension",
  "version": "1.0",
  "description": "Allows you to watch SFCON and Group6 recordings on the DefconExpanded Replay Viewer",
  "author": "KezzaMcFezza",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["*://group6.info/*", "*://sfcon.demoszenen.de/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
} 